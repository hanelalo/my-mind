{
  "$schema": "https://raw.githubusercontent.com/nicholasrice/tauri-schema/refs/heads/main/tauri.conf.schema.json",
  "productName": "My Mind",
  "version": "0.1.0",
  "identifier": "com.mymind.app",
  "build": {
    "frontendDist": "../packages/web/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm --filter web dev",
    "beforeBuildCommand": "pnpm --filter web build"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  }
}
